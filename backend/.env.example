# Modo Local (SQLite) - por defecto, no necesita configuración
# Solo ejecuta: python run.py

# ============================================
# Modo Producción (Supabase / PostgreSQL)
# ============================================
# Descomenta y configura para usar PostgreSQL:
#
# APP_ENV=production
# DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXXXXXXXX.supabase.co:5432/postgres
# API_HOST=0.0.0.0
# API_PORT=8000
#
# Luego ejecuta las migraciones:
#   alembic upgrade head
#
# Y finalmente inicia el servidor:
#   python run.py
